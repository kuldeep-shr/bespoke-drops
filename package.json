{
  "name": "bespoke-drops",
  "version": "1.0.0",
  "description": "Backend for BeSpoke Drops — limited-edition fashion drops with fair, correct stock claiming under load.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "ts-node src/scripts/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "loadtest": "ts-node src/scripts/loadtest.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "mongoose": "^8.5.1",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@mongodb-js/mongodb-downloader": "^1.1.15",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "mongodb-memory-server": "^11.2.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  }
}
